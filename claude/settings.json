{
  "env": {
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_AFK_TIMEOUT_MS": "3600000"
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:zod.dev)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:developer.chrome.com)",
      "WebFetch(domain:microsoft.ai)",
      "WebFetch(domain:techcommunity.microsoft.com)",
      "WebFetch(domain:ai.azure.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:azure.status.microsoft)",
      "WebFetch(domain:status.ai.azure.com)",
      "Bash(git add*)",
      "Bash(git pull*)",
      "Bash(git commit*)",
      "Bash(git fetch *)",
      "Bash(git show:*)",
      "Bash(git log:*)",
      "Bash(gh pr view*)",
      "Bash(gh pr diff*)",
      "Bash(gh issue view*)",
      "Bash(glab mr view*)",
      "Bash(glab mr diff*)",
      "Bash(glab ci view:*)",
      "Bash(glab --version)",
      "Bash(asdf list *)",
      "Bash(cursor --version)",
      "Bash(agent --help)",
      "Bash(node --version:*)",
      "Bash(npm view:*)",
      "Bash(npm info:*)",
      "Bash(yarn why:*)",
      "Bash(yarn info:*)",
      "Bash(yarn npm info:*)",
      "Bash(yarn tsc:*)",
      "Bash(yarn test)",
      "Bash(npx tsc --noEmit)",
      "Bash(bundle exec rubocop:*)",
      "Bash(bundle exec rspec:*)",
      "Bash(cmux read-screen *)",
      "Bash(cmux capture-pane *)",
      "Bash(cmux list-workspaces *)",
      "Bash(cmux list-panes *)",
      "Bash(cmux list-pane-surfaces *)",
      "Bash(cmux read-surface *)",
      "Bash(cmux --help)",
      "mcp__plugin_Notion_notion__notion-fetch",
      "mcp__plugin_Notion_notion__notion-query-data-sources",
      "mcp__claude_ai_Notion__notion-fetch",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs",
      "mcp__plugin_sentry_sentry__get_sentry_resource",
      "mcp__claude_ai_Figma__get_screenshot",
      "mcp__chrome-devtools__navigate_page",
      "mcp__chrome-devtools__list_pages",
      "mcp__chrome-devtools__take_screenshot",
      "mcp__chrome-devtools__close_page",
      "mcp__chrome-devtools__new_page",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__new_page",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__navigate_page",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__list_pages",
      "mcp__plugin_playwright_playwright__browser_navigate",
      "mcp__plugin_playwright_playwright__browser_tabs",
      "mcp__plugin_playwright_playwright__browser_take_screenshot",
      "mcp__plugin_playwright_playwright__browser_snapshot",
      "mcp__plugin_playwright_playwright__browser_click",
      "mcp__plugin_playwright_playwright__browser_evaluate",
      "mcp__plugin_playwright_playwright__browser_wait_for",
      "mcp__plugin_playwright_playwright__browser_handle_dialog",
      "mcp__plugin_playwright_playwright__browser_close",
      "mcp__plugin_playwright_playwright__browser_console_messages",
      "mcp__plugin_playwright_playwright__browser_network_requests",
      "mcp__plugin_playwright_playwright__browser_press_key",
      "Skill(git-commit)",
      "Bash(node ~/.claude/plugins/cache/openai-codex/codex/*)"
    ],
    "deny": ["Edit(~/.claude/plugins/cache/openai-codex/**)"],
    "defaultMode": "default",
    "additionalDirectories": ["~/.claude/plugins/cache/openai-codex"]
  },
  "model": "claude-fable-5[1m]",
  "fallbackModel": ["claude-opus-4-7"],
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude Code needs your attention\" with title \"Claude Code\"'"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "rm -rf .playwright-mcp 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude/statusline-powerline.sh"
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "sentry@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "codex@openai-codex": true,
    "coderabbit@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "language": "Japanese",
  "effortLevel": "high",
  "advisorModel": "opus",
  "askUserQuestionTimeout": "never",
  "skipWorkflowUsageWarning": true,
  "theme": "auto",
  "autoCompactEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
